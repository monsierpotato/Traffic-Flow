{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TrafficFlow Benchmark Run Summary",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "backend",
    "split_bucket",
    "sequence_count",
    "total_raw_detection_rows",
    "total_raw_track_rows",
    "total_raw_counting_events",
    "elapsed_ms",
    "sequences"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string"},
    "backend": {"type": "string"},
    "split_bucket": {"type": "string"},
    "sequence_count": {"type": "integer", "minimum": 1},
    "total_raw_detection_rows": {"type": "integer", "minimum": 0},
    "total_raw_track_rows": {"type": "integer", "minimum": 0},
    "total_raw_counting_events": {"type": "integer", "minimum": 0},
    "elapsed_ms": {"type": "number", "minimum": 0},
    "sequences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sequence_id", "geometry_version", "raw_detection_rows", "raw_track_rows", "raw_counting_events"]
      }
    }
  },
  "additionalProperties": true
}
