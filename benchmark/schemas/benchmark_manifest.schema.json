{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TrafficFlow Benchmark Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "git_commit",
    "dataset_split",
    "protocol_version",
    "model_path",
    "model_sha256",
    "imgsz",
    "confidence",
    "iou",
    "tracker_config",
    "counting_config",
    "geometry_versions",
    "device",
    "software",
    "started_at",
    "completed_at",
    "artifacts"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "git_commit": {"type": "string", "minLength": 1},
    "dataset_split": {"type": "string"},
    "split_bucket": {"type": "string"},
    "protocol_version": {"type": "integer"},
    "model_path": {"type": "string"},
    "model_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "imgsz": {"type": "integer", "minimum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "iou": {"type": "number", "minimum": 0, "maximum": 1},
    "tracker_config": {"type": "string"},
    "counting_config": {"type": "string"},
    "geometry_versions": {"type": "object"},
    "device": {"type": "string"},
    "gpu": {"type": "string"},
    "backend": {"type": "string"},
    "sequences": {"type": "array", "items": {"type": "string"}},
    "software": {"type": "object"},
    "artifacts": {"type": "object"},
    "started_at": {"type": "string"},
    "completed_at": {"type": "string"}
  },
  "additionalProperties": true
}
